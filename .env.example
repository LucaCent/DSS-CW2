# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_USER=
DB_PASS=
DB_NAME=

# Express session secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Password pepper — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PEPPER=

# AES-256-GCM encryption key — must be exactly 64 characters
ENCRYPTION_KEY=