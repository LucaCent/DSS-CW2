# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_postgres_user
DB_PASS=your_postgres_password
DB_NAME=secure_blog

# Session secret — use a long random string (min 64 characters)
SESSION_SECRET=replace_with_a_long_random_string_at_least_64_characters

# Pepper — a secret appended to passwords before hashing (min 32 characters)
PEPPER=replace_with_a_random_pepper_string_at_least_32_chars

# AES-256 encryption key — must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CSRF secret — used for CSRF token generation (min 32 characters)
CSRF_SECRET=replace_with_a_random_csrf_secret_string

# Application port
PORT=3000