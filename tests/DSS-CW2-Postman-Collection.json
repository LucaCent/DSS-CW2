{
  "info": {
    "name": "DSS-CW2 Security Test Suite",
    "_postman_id": "dss-cw2-security-tests",
    "description": "Automated security tests for CMP-6045B Group 15.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "csrfToken",
      "value": "",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "postrequest",
      "script": {
        "exec": [
          "const newToken = pm.response.headers.get('X-New-CSRF-Token');",
          "if (newToken) { pm.collectionVariables.set('csrfToken', newToken); }"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "0. Setup",
      "item": [
        {
          "name": "SETUP: GET CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.test('Response contains csrfToken', () => pm.expect(json).to.have.property('csrfToken'));",
                  "pm.test('Token is 64-char hex string', () => pm.expect(json.csrfToken).to.match(/^[0-9a-f]{64}$/));",
                  "pm.collectionVariables.set('csrfToken', json.csrfToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/csrf-token"
          }
        }
      ]
    },
    {
      "name": "1. CSRF Protection",
      "item": [
        {
          "name": "CSRF-01: POST Login WITHOUT CSRF Token → 403",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('CSRF-less request returns 403', () => pm.response.to.have.status(403));",
                  "pm.test('Response contains error field', () => pm.expect(pm.response.json()).to.have.property('error'));",
                  "pm.test('Error does not reveal internals', () => {",
                  "  const body = JSON.stringify(pm.response.json());",
                  "  pm.expect(body).to.not.include('stack');",
                  "  pm.expect(body).to.not.include('node_modules');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser1\", \"password\": \"Testuser1+\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "CSRF-02: POST Register WITHOUT CSRF Token → 403",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('CSRF-less register returns 403', () => pm.response.to.have.status(403));",
                  "pm.test('Response has error property', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"hacker\", \"email\": \"h@h.com\", \"password\": \"Test1!\"}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        }
      ]
    },
    {
      "name": "2. Account Enumeration Prevention",
      "item": [
        {
          "name": "ENUM-01: POST Login — non-existent username → 401 generic",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Non-existent username returns 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error message is generic', () => pm.expect(pm.response.json().error).to.equal('Invalid credentials'));",
                  "pm.test('Response does not reveal username does not exist', () => {",
                  "  const body = JSON.stringify(pm.response.json());",
                  "  pm.expect(body).to.not.include('user not found');",
                  "  pm.expect(body).to.not.include('does not exist');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"fakeuserxyz99\", \"password\": \"WrongPass1!\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "ENUM-02: POST Login — real username wrong password → same 401",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401', () => pm.response.to.have.status(401));",
                  "pm.test('Same generic message — no enumeration possible', () => {",
                  "  pm.expect(pm.response.json().error).to.equal('Invalid credentials');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser1\", \"password\": \"definitelywrong99\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "3. SQL Injection Resistance",
      "item": [
        {
          "name": "SQLI-01: POST Login — SQL injection in username → rejected safely",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('SQL injection does not bypass auth', () => pm.response.to.not.have.status(200));",
                  "pm.test('Status is 400, 401, or 403', () => pm.expect([400,401,403]).to.include(pm.response.code));",
                  "pm.test('No SQL error details in response', () => {",
                  "  const body = JSON.stringify(pm.response.json());",
                  "  pm.expect(body).to.not.include('syntax error');",
                  "  pm.expect(body).to.not.include('PostgreSQL');",
                  "  pm.expect(body).to.not.include('SELECT');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"' OR 1=1 --\", \"password\": \"anything\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "SQLI-02: GET /posts/search — UNION injection → rejected safely",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('UNION injection does not return 500', () => pm.response.to.not.have.status(500));",
                  "pm.test('No SQL error details leak', () => {",
                  "  const body = JSON.stringify(pm.response.json());",
                  "  pm.expect(body).to.not.include('syntax error');",
                  "  pm.expect(body).to.not.include('PostgreSQL');",
                  "  pm.expect(body).to.not.include('password_hash');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/posts/search?q=' UNION SELECT username, password_hash FROM users --",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "posts",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "' UNION SELECT username, password_hash FROM users --"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Brute Force & Account Lockout",
      "item": [
        {
          "name": "LOCKOUT-01: 5 failed logins → account locked",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401', () => pm.response.to.have.status(401));",
                  "const json = pm.response.json();",
                  "if (json.error && json.error.includes('locked')) {",
                  "  pm.test('Lockout message returned', () => pm.expect(json.error).to.include('locked'));",
                  "  console.log('Account lockout confirmed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser1\", \"password\": \"WrongPass1!\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "5. Rate Limiting",
      "item": [
        {
          "name": "RATE-01: 11+ rapid login attempts → 429",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Rate limiter fires (429) or request rejected (401)', () => {",
                  "  pm.expect([401, 429]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 429) {",
                  "  pm.test('429 response has error message', () => pm.expect(pm.response.json()).to.have.property('error'));",
                  "  console.log('Rate limiter confirmed active');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"rateLimitTest\", \"password\": \"WrongPass1!\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "6. Access Control & IDOR",
      "item": [
        {
          "name": "IDOR-00: GET /posts (public) → 200 OK",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Public post listing returns 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has posts array', () => pm.expect(pm.response.json()).to.have.property('posts'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/posts"
          }
        },
        {
          "name": "IDOR-00b: POST /posts without auth → 401",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Creating post without login returns 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error message present', () => pm.expect(pm.response.json()).to.have.property('error'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"Hacker post\", \"content\": \"Should not be allowed\"}"
            },
            "url": "{{baseUrl}}/posts"
          }
        },
        {
          "name": "IDOR-01: DELETE /posts/1 without auth → 401",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Deleting post without session returns 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "url": "{{baseUrl}}/posts/1"
          }
        }
      ]
    },
    {
      "name": "7. XSS — Output Encoding",
      "item": [
        {
          "name": "XSS-01: POST /posts with script tag — blocked without auth",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('XSS post attempt blocked or rejected', () => pm.expect([401,400,403]).to.include(pm.response.code));",
                  "pm.test('Response does not echo back raw script tag', () => {",
                  "  pm.expect(pm.response.text()).to.not.include('<script>alert');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"title\": \"<script>alert(1)</script>\", \"content\": \"<img src=x onerror=alert(1)>\"}"
            },
            "url": "{{baseUrl}}/posts"
          }
        }
      ]
    },
    {
      "name": "8. Password Strength",
      "item": [
        {
          "name": "PWD-01: POST /auth/register — weak password → 400",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Weak password returns 400', () => pm.response.to.have.status(400));",
                  "pm.test('Validation error message present', () => pm.expect(pm.response.json()).to.have.property('error'));",
                  "pm.test('No account created', () => pm.expect(pm.response.code).to.not.equal(201));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"weakpwduser\", \"email\": \"weak@test.com\", \"password\": \"weak\", \"authMethod\": \"captcha\", \"captchaCode\": \"test\"}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        }
      ]
    },
    {
      "name": "9. 2FA / TOTP",
      "item": [
        {
          "name": "TOTP-01: POST Login — correct password, no 2FA code → requires2FA",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 200 with requires2FA flag', () => {",
                  "  pm.expect([200, 401]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  pm.test('Response indicates 2FA required', () => {",
                  "    pm.expect(pm.response.json()).to.have.property('requires2FA');",
                  "    pm.expect(pm.response.json().requires2FA).to.equal(true);",
                  "  });",
                  "  console.log('2FA challenge confirmed');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"testuser1\", \"password\": \"Testuser1+\"}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "10. Error Handling & Information Disclosure",
      "item": [
        {
          "name": "ERR-01: GET unknown route → no internals exposed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Unknown route returns 200 (SPA) or 404', () => pm.expect([200,404]).to.include(pm.response.code));",
                  "pm.test('Response does not reveal internal route structure', () => {",
                  "  const body = pm.response.text();",
                  "  pm.expect(body).to.not.include('node_modules');",
                  "  pm.expect(body).to.not.include('at Object.');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/secret-panel"
          }
        },
        {
          "name": "ERR-02: POST malformed JSON → 400 generic, no stack trace",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({ url: pm.collectionVariables.get('baseUrl') + '/auth/csrf-token', method: 'GET' },",
                  "  function(err, res) { if (!err) pm.collectionVariables.set('csrfToken', res.json().csrfToken); });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Malformed JSON returns 400 or 403', () => pm.expect([400,403]).to.include(pm.response.code));",
                  "pm.test('No stack trace in response', () => {",
                  "  const body = JSON.stringify(pm.response.json());",
                  "  pm.expect(body).to.not.match(/at\\s+.+:\\d+:\\d+/);",
                  "  pm.expect(body).to.not.include('node_modules');",
                  "  pm.expect(body).to.not.include('.js:');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-csrf-token",
                "value": "{{csrfToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{this is not valid json!!!"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "11. Security Headers",
      "item": [
        {
          "name": "HDR-01: GET / — verify all security headers present",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('X-Frame-Options: DENY present', () => pm.expect(pm.response.headers.get('x-frame-options')).to.equal('DENY'));",
                  "pm.test('Content-Security-Policy present', () => pm.expect(pm.response.headers.get('content-security-policy')).to.exist);",
                  "pm.test('CSP includes frame-ancestors none', () => pm.expect(pm.response.headers.get('content-security-policy')).to.include('frame-ancestors'));",
                  "pm.test('Strict-Transport-Security present', () => pm.expect(pm.response.headers.get('strict-transport-security')).to.exist);",
                  "pm.test('X-Content-Type-Options: nosniff present', () => pm.expect(pm.response.headers.get('x-content-type-options')).to.equal('nosniff'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/"
          }
        }
      ]
    }
  ]
}